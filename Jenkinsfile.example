#!/usr/bin/env groovy

/**
 * Example Jenkinsfile — how to USE this shared library from any project.
 *
 * STEP 1: Register the library in Jenkins:
 *   Manage Jenkins → Configure System → Global Pipeline Libraries
 *   Name: jenkins-shared-lib
 *   Default Version: main
 *   Source: Git → https://github.com/your-org/jenkins-shared-lib.git
 *
 * STEP 2: Use it in your project's Jenkinsfile (two options below)
 */

// ─────────────────────────────────────────────────────────
// OPTION A: Use the full myPipeline() wrapper (simplest)
// ─────────────────────────────────────────────────────────
@Library('jenkins-shared-lib') _

myPipeline(
    appName:        'my-java-service',
    dockerRegistry: 'myrepo',       // e.g. docker.io/myusername
    buildTool:      'Maven',         // or 'Gradle'
    branch:         'main',          // branch to build Docker image on
    imageTag:       env.BUILD_NUMBER
)


// ─────────────────────────────────────────────────────────
// OPTION B: Use individual steps for more control
// ─────────────────────────────────────────────────────────
